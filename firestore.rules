// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: discounts
// Document ID: {discountId}
// Fields:
//   - id: string (required) - Unique identifier
//   - title: string (required) - Short title
//   - description: string (optional) - Detailed description
//   - discountAmount: string (optional) - Amount/percentage
//   - store: string (required) - Store name
//   - category: string (optional) - Product category
//   - image: string (optional) - Image URL
//   - source: string (optional) - Source URL
//   - validUntil: string (optional, ISO8601) - Expiration
//   - createdAt: string (required, ISO8601) - Scraped timestamp
//   - isVerified: boolean (optional) - AI verification status
//
// Collection: config
// Document ID: global
// Fields:
//   - lastSync: string (optional, ISO8601) - Last sync timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abrperd@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidDiscount(data) {
      return data.keys().hasAll(['id', 'title', 'store', 'createdAt']) &&
             data.id is string &&
             data.title is string && data.title.size() < 200 &&
             data.store is string && data.store.size() < 100 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /discounts/{discountId} {
      // Allow public read access for the aggregator
      allow read: if true;
      
      // Allow writes for the prototype sync process
      allow create: if isValidDiscount(request.resource.data);
      allow update: if isValidDiscount(request.resource.data);
      allow delete: if isAdmin();
    }

    match /config/global {
      allow read: if true;
      allow write: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
